{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "devflow",
  "version": "0.4.0",
  "identifier": "dev.devflow.app",
  "build": {
    "beforeDevCommand": {
      "script": "bun run dev",
      "cwd": "../ui"
    },
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": {
      "script": "bun run build",
      "cwd": "../ui"
    },
    "frontendDist": "../ui/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "devflow",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "visible": false,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
