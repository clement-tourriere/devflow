amends "package://github.com/jdx/hk/releases/download/v1.39.0/hk@1.39.0#/Config.pkl"

local local_hooks = new Mapping<String, Step> {
    ["cargo-fmt"] {
        glob = "**/*.rs"
        exclude = ".hk/**"
        check = "cargo fmt -- --check"
        fix = "cargo fmt"
    }
    ["cargo-clippy"] {
        glob = "**/*.rs"
        exclude = ".hk/**"
        check = "cargo clippy --workspace -- -D warnings"
        fix = "cargo clippy --workspace --fix --allow-dirty --allow-staged -- -D warnings"
    }
}

hooks {
    ["pre-commit"] {
        fix = true
        stash = "git"
        steps {
            ...local_hooks
        }
    }
    ["check"] {
        steps {
            ...local_hooks
        }
    }
    ["fix"] {
        fix = true
        steps {
            ...local_hooks
        }
    }
}
